# ──────────────────────────────────────────────────────
# VPS uchun .env.prod fayli — nusxa oling: cp .env.prod.example .env.prod
# ──────────────────────────────────────────────────────

# Database (docker-compose ichida postgres service nomi ishlatiladi)
POSTGRES_PASSWORD=your_strong_password_here

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=7d

# App
PORT=3001
NODE_ENV=production
APP_BASE_URL=http://46.202.191.210:3001
CORS_ORIGINS=http://46.202.191.210,http://46.202.191.210:3000,http://localhost:3000

# WhatsApp (Whapi.cloud)
WHAPI_API_URL=https://gate.whapi.cloud/
WHAPI_TOKEN=your_whapi_token_here
WHATSAPP_BOT_PHONE=998955775454

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# SMS Gateway (Android telefon public IP)
SMS_GATEWAYS=http://85.54.66.57:8080
SMS_GATEWAY_USER=sms
SMS_GATEWAY_PASS=your_sms_pass_here

# Billing
BILLING_MONTHLY_AMOUNT=12000
BILLING_YEARLY_AMOUNT=80000

# Turnstile / Hikvision
TURNSTILE_ENABLED=false
TURNSTILE_IP=
TURNSTILE_PORT=
TURNSTILE_USERNAME=
TURNSTILE_PASSWORD=
HIKVISION_INSECURE_TLS=true

# Payment gateway (keyinroq)
PAYMENT_GATEWAY_API_URL=https://api.freedompay.kg/v1
PAYMENT_GATEWAY_MERCHANT_ID=
PAYMENT_GATEWAY_SECRET_KEY=
