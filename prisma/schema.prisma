// prisma/schema.prisma - COMPLETE VERSION WITH TELEGRAM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  DISTRICT_ADMIN
  SCHOOL_ADMIN
  DIRECTOR
  TEACHER
  STUDENT
  PARENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  LEAVE
  HOLIDAY
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

model User {
  id            String      @id @default(uuid())
  username      String      @unique
  password      String
  email         String?
  role          UserRole
  status        UserStatus  @default(ACTIVE)
  
  student       Student?
  teacher       Teacher?
  director      Director?
  parent        Parent?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model District {
  id            String      @id @default(uuid())
  name          String
  region        String
  code          String      @unique
  
  schools       School[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model School {
  id            String      @id @default(uuid())
  districtId    String?
  district      District?   @relation(fields: [districtId], references: [id])
  
  name          String
  code          String      @unique
  address       String
  phone         String?
  email         String?
  
  classes       Class[]
  students      Student[]
  teachers      Teacher[]
  directors     Director[]
  attendances   Attendance[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Class {
  id            String      @id @default(uuid())
  schoolId      String
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  grade         Int
  section       String
  academicYear  String
  
  students      Student[]
  teacherClasses TeacherClass[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@unique([schoolId, grade, section, academicYear])
}

model Student {
  id            String      @id @default(uuid())
  userId        String?     @unique
  user          User?       @relation(fields: [userId], references: [id])
  
  schoolId      String
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId       String
  class         Class       @relation(fields: [classId], references: [id])
  
  firstName     String
  lastName      String
  middleName    String?
  dateOfBirth   DateTime?
  gender        Gender
  phone         String?
  
  telegramId        String?  @unique
  telegramUsername  String?
  telegramChatId    String?
  isTelegramActive  Boolean  @default(false)
  
  photo         String?
  facePersonId  String?     @unique
  enrollNumber  String?     @unique

  // ==========================================
  // ✅ SMS TO'LOV SOZLAMALARI
  // ==========================================
  isSmsEnabled       Boolean   @default(true)
  smsPaidUntil       DateTime?
  smsPaymentType     String?   // "MONTHLY", "YEARLY"
  smsReminderSent    Boolean   @default(false)
  
  parents       Parent[]
  attendances   Attendance[]
  payments      Payment[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([schoolId])
  @@index([classId])
}

model Teacher {
  id            String      @id @default(uuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  schoolId      String
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  firstName     String
  lastName      String
  phone         String
  subjects      String[]
  
  telegramId        String?  @unique
  telegramUsername  String?
  telegramChatId    String?
  isTelegramActive  Boolean  @default(false)
  
  photo         String?
  facePersonId  String?     @unique
  enrollNumber  String?     @unique
  
  teacherClasses TeacherClass[]
  
  schedule              TeacherSchedule?
  payrollAttendances    TeacherAttendance[] @relation("TeacherPayrollAttendance")
  payrolls              TeacherPayroll[]    @relation("TeacherPayroll")
  
  attendances   Attendance[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([schoolId])
}

model TeacherClass {
  id        String   @id @default(uuid())
  
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([teacherId, classId])
}

model TeacherSchedule {
  id        String   @id @default(uuid())
  teacherId String   @unique
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  workDays       Json
  startTime      String
  endTime        String
  hoursPerDay    Float
  daysPerWeek    Int
  hoursPerMonth  Float
  
  baseSalary     Float
  hourlyRate     Float
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("teacher_schedules")
}

model TeacherAttendance {
  id        String   @id @default(uuid())
  teacherId String
  teacher   Teacher  @relation("TeacherPayrollAttendance", fields: [teacherId], references: [id], onDelete: Cascade)
  
  date      DateTime
  
  checkInTime   DateTime?
  checkOutTime  DateTime?
  
  workDuration  Float?
  isLate        Boolean  @default(false)
  lateMinutes   Int      @default(0)
  leftEarly     Boolean  @default(false)
  earlyMinutes  Int      @default(0)
  isAbsent      Boolean  @default(false)
  
  status        AttendanceStatus @default(ABSENT)
  notes         String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([teacherId, date])
  @@index([teacherId, date])
  @@map("teacher_attendances")
}

model TeacherPayroll {
  id        String   @id @default(uuid())
  teacherId String
  teacher   Teacher  @relation("TeacherPayroll", fields: [teacherId], references: [id], onDelete: Cascade)
  
  month     String
  
  expectedDays       Int
  expectedHours      Float
  baseSalary         Float
  
  totalDaysWorked    Int
  totalHoursWorked   Float
  
  lateDays           Int      @default(0)
  lateMinutes        Int      @default(0)
  earlyLeaveDays     Int      @default(0)
  earlyLeaveMinutes  Int      @default(0)
  absentDays         Int      @default(0)
  
  missedHours        Float
  penaltyAmount      Float
  
  bonusAmount        Float    @default(0)
  bonusReason        String?
  
  actualSalary       Float
  
  isPaid             Boolean  @default(false)
  paidAt             DateTime?
  paymentMethod      String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([teacherId, month])
  @@index([teacherId, month])
  @@map("teacher_payrolls")
}

model Director {
  id            String      @id @default(uuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  schoolId      String
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  firstName     String
  lastName      String
  phone         String
  
  telegramId        String?  @unique
  telegramUsername  String?
  telegramChatId    String?
  isTelegramActive  Boolean  @default(false)
  
  photo         String?
  facePersonId  String?     @unique
  enrollNumber  String?     @unique
  
  attendances   Attendance[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([schoolId])
}

model Parent {
  id               String      @id @default(uuid())
  userId           String?     @unique
  user             User?       @relation(fields: [userId], references: [id])
  
  studentId        String
  student          Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  firstName        String
  lastName         String
  phone            String      @unique
  
  telegramId        String?  @unique
  telegramUsername  String?
  telegramChatId    String?
  isTelegramActive  Boolean  @default(false)
  
  relationship     String
  
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Attendance {
  id            String           @id @default(uuid())
  schoolId      String
  school        School           @relation(fields: [schoolId], references: [id])
  
  studentId     String?
  student       Student?         @relation(fields: [studentId], references: [id])
  teacherId     String?
  teacher       Teacher?         @relation(fields: [teacherId], references: [id])
  directorId    String?
  director      Director?        @relation(fields: [directorId], references: [id])
  
  date          DateTime
  status        AttendanceStatus
  checkInTime   DateTime?
  checkOutTime  DateTime?
  lateMinutes   Int?
  lateCount     Int      @default(0)
  deviceId      String?
  notes         String?
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  
  @@unique([studentId, date])
  @@unique([teacherId, date])
  @@unique([directorId, date])
  @@index([schoolId, date])
}

model Payment {
  id            String         @id @default(uuid())
  studentId     String
  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  amount        Float
  dueDate       DateTime
  paidDate      DateTime?
  status        PaymentStatus  @default(PENDING)
  month         String
  academicYear  String
  notes         String?
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  @@unique([studentId, month])
  @@index([studentId])
  @@index([status])
}

model Notification {
  id            String      @id @default(uuid())
  recipientType String
  recipientId   String
  
  type          String
  title         String
  message       String
  sentVia       String
  
  isSent        Boolean     @default(false)
  sentAt        DateTime?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([recipientId, isSent])
}

model TelegramSession {
  id            String   @id @default(uuid())
  chatId        String   @unique
  telegramId    String
  
  userId        String?
  userType      String?
  state         String   @default("START")
  data          Json?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([chatId])
  @@index([telegramId])
}

model SmsLog {
  id        String   @id @default(uuid())
  recipient String
  message   String
  status    String
  sentAt    DateTime @default(now())
  
  @@index([recipient])
  @@index([sentAt])
}
