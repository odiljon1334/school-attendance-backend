generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN      // Web only
  DISTRICT_ADMIN   // Web only
  SCHOOL_ADMIN     // Web only
  DIRECTOR         // Web + Telegram + Turnstile
  TEACHER          // Web + Telegram + Turnstile
  STUDENT          // Turnstile only (Face Recognition)
  PARENT           // Telegram only
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  EXCUSED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

model User {
  id            String      @id @default(uuid())
  username      String      @unique
  password      String
  email         String?
  role          UserRole
  status        UserStatus  @default(ACTIVE)
  
  student       Student?
  teacher       Teacher?
  director      Director?
  parent        Parent?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model District {
  id            String      @id @default(uuid())
  name          String
  region        String
  code          String      @unique
  
  schools       School[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model School {
  id            String      @id @default(uuid())
  districtId    String?
  district      District?   @relation(fields: [districtId], references: [id])
  
  name          String
  code          String      @unique
  address       String
  phone         String?
  email         String?
  
  classes       Class[]
  students      Student[]
  teachers      Teacher[]
  directors     Director[]
  attendances   Attendance[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Class {
  id            String      @id @default(uuid())
  schoolId      String
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  grade         Int
  section       String
  academicYear  String
  
  students      Student[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@unique([schoolId, grade, section, academicYear])
}

// ============================
// STUDENT - Turniket uchun
// ============================
model Student {
  id            String      @id @default(uuid())
  userId        String?     @unique
  user          User?       @relation(fields: [userId], references: [id])
  
  schoolId      String
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId       String
  class         Class       @relation(fields: [classId], references: [id])
  
  // Personal info
  firstName     String
  lastName      String
  middleName    String?
  dateOfBirth   DateTime?
  gender        Gender
  phone         String?
  telegramId    String?
  
  // CRITICAL: Photo for turnstile face recognition
  // Format: JPEG/PNG base64 or file path
  // File naming: {studentId}_2_0_{studentId}_0.jpg
  photo         String?     // Passport-style photo for face recognition
  
  // Additional
  enrollNumber  String?     @unique  // For turnstile device ID
  
  parents       Parent[]
  attendances   Attendance[]
  payments      Payment[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([schoolId])
  @@index([classId])
}

// ============================
// TEACHER - Turniket uchun
// ============================
model Teacher {
  id            String      @id @default(uuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  schoolId      String
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  // Personal info
  firstName     String
  lastName      String
  phone         String
  telegramId    String?
  subjects      String[]
  
  // CRITICAL: Photo for turnstile face recognition
  photo         String?     // Passport-style photo
  
  // Additional
  enrollNumber  String?     @unique  // For turnstile device ID
  
  attendances   Attendance[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([schoolId])
}

// ============================
// DIRECTOR - Turniket uchun
// ============================
model Director {
  id            String      @id @default(uuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  schoolId      String
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  // Personal info
  firstName     String
  lastName      String
  phone         String
  telegramId    String?
  
  // CRITICAL: Photo for turnstile face recognition
  photo         String?     // Passport-style photo
  
  // Additional
  enrollNumber  String?     @unique  // For turnstile device ID
  
  attendances   Attendance[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([schoolId])
}

// ============================
// PARENT - Telegram only (NO photo needed)
// ============================
model Parent {
  id               String      @id @default(uuid())
  userId           String?     @unique
  user             User?       @relation(fields: [userId], references: [id])
  
  studentId        String
  student          Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  firstName        String
  lastName         String
  phone            String      @unique
  telegramId       String?     @unique
  telegramChatId   String?
  isTelegramActive Boolean     @default(false)
  
  relationship     String      // father, mother, guardian
  
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Attendance {
  id            String           @id @default(uuid())
  schoolId      String
  school        School           @relation(fields: [schoolId], references: [id])
  
  // Polymorphic - student OR teacher OR director
  studentId     String?
  student       Student?         @relation(fields: [studentId], references: [id])
  teacherId     String?
  teacher       Teacher?         @relation(fields: [teacherId], references: [id])
  directorId    String?
  director      Director?        @relation(fields: [directorId], references: [id])
  
  date          DateTime
  status        AttendanceStatus
  checkInTime   DateTime?
  checkOutTime  DateTime?
  lateMinutes   Int?
  deviceId      String?          // Turnstile device ID
  notes         String?
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  
  @@unique([studentId, date])
  @@unique([teacherId, date])
  @@unique([directorId, date])
  @@index([schoolId, date])
}

model Payment {
  id            String         @id @default(uuid())
  studentId     String
  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  amount        Float
  dueDate       DateTime
  paidDate      DateTime?
  status        PaymentStatus  @default(PENDING)
  month         String         // "2026-02"
  academicYear  String
  notes         String?
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  @@unique([studentId, month])
  @@index([studentId])
  @@index([status])
}

model Notification {
  id            String      @id @default(uuid())
  recipientType String      // PARENT, TEACHER, DIRECTOR
  recipientId   String
  
  type          String      // ATTENDANCE, PAYMENT, REMINDER
  title         String
  message       String
  sentVia       String      // TELEGRAM, SMS
  
  isSent        Boolean     @default(false)
  sentAt        DateTime?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([recipientId, isSent])
}
